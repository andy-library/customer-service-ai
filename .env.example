# Copy: cp .env.example .env
# NEVER commit .env

# ---- Database (docker compose) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=csai
DB_USER=csai
DB_PASSWORD=csai

# ============================================================
# 阿里云百炼 + glm-5.1（本项目 = OpenAI 兼容协议）
# ============================================================
# Claude Code / CC Switch 使用的是 Anthropic 协议端点：
#   https://dashscope.aliyuncs.com/apps/anthropic
# 本 Spring AI 应用必须使用 OpenAI 兼容端点（同一个 API Key）：
#   https://dashscope.aliyuncs.com/compatible-mode/v1
#
# 新加坡 / 美国地域请换官方文档中的对应域名。
# ============================================================

CS_AI_DEFAULT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CS_AI_DEFAULT_API_KEY=replace-me

# Chat roles — currently all glm-5.1 (change later for cost tiers)
CS_AI_CLASSIFIER_BASE_URL=
CS_AI_CLASSIFIER_API_KEY=
CS_AI_CLASSIFIER_MODEL=glm-5.1

CS_AI_ANSWER_STRONG_BASE_URL=
CS_AI_ANSWER_STRONG_API_KEY=
CS_AI_ANSWER_STRONG_MODEL=glm-5.1

CS_AI_ANSWER_FAST_BASE_URL=
CS_AI_ANSWER_FAST_API_KEY=
CS_AI_ANSWER_FAST_MODEL=glm-5.1

# Embedding for RAG (NOT glm-5.1)
CS_AI_EMBEDDING_BASE_URL=
CS_AI_EMBEDDING_API_KEY=
CS_AI_EMBEDDING_MODEL=text-embedding-v3
CS_AI_EMBEDDING_DIMENSIONS=1024

CS_AI_WORKER_ID=1
SERVER_PORT=8081

# ---- Optional: if you later put an OpenAI-compatible local gateway in front ----
# CS_AI_DEFAULT_BASE_URL=http://127.0.0.1:xxxx/v1
# Do NOT point Spring AI at CC Switch Anthropic proxy by default:
#   http://127.0.0.1:15721  (Claude Code local proxy; not the primary path for this app)
