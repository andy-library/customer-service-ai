# Copy to .env and fill real values. NEVER commit .env.
# cp .env.example .env

DB_HOST=localhost
DB_PORT=5432
DB_NAME=csai
DB_USER=csai
DB_PASSWORD=csai

# ---- Required: OpenAI-compatible default endpoint ----
# Examples:
#   OpenAI:     https://api.openai.com
#   DeepSeek:   https://api.deepseek.com
#   通义兼容:    https://dashscope.aliyuncs.com/compatible-mode/v1
#   智谱兼容:    https://open.bigmodel.cn/api/paas/v4
#   本地网关:    http://127.0.0.1:8000/v1
CS_AI_DEFAULT_BASE_URL=https://api.openai.com
CS_AI_DEFAULT_API_KEY=replace-me

# Optional: override per role (empty = fall back to DEFAULT_*)
CS_AI_CLASSIFIER_BASE_URL=
CS_AI_CLASSIFIER_API_KEY=
CS_AI_CLASSIFIER_MODEL=gpt-4o-mini

CS_AI_ANSWER_STRONG_BASE_URL=
CS_AI_ANSWER_STRONG_API_KEY=
CS_AI_ANSWER_STRONG_MODEL=gpt-4o

CS_AI_ANSWER_FAST_BASE_URL=
CS_AI_ANSWER_FAST_API_KEY=
CS_AI_ANSWER_FAST_MODEL=gpt-4o-mini

CS_AI_EMBEDDING_BASE_URL=
CS_AI_EMBEDDING_API_KEY=
CS_AI_EMBEDDING_MODEL=text-embedding-3-small
# Must match model output dimension (and spring.ai.vectorstore.pgvector.dimensions)
CS_AI_EMBEDDING_DIMENSIONS=1536

# Framework snowflake worker id (0-1023)
CS_AI_WORKER_ID=1

# Optional app port when using scripts/run-real.sh
# SERVER_PORT=8081
