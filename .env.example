# Copy: cp .env.example .env
# Or for local llama + Dify: cp .env.local-llama.example .env
# NEVER commit .env

# ---- Database (docker compose) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=csai
DB_USER=csai
DB_PASSWORD=csai

# ============================================================
# 模型源切换（应用启动时生效，改完需重启）
#   local  = 本机 llama.cpp（默认 Chat:18080 Embed:18081）
#   cloud  = 百炼 / 其他 OpenAI 兼容云端
# ============================================================
CS_AI_MODEL_SOURCE=local

# ============================================================
# 知识库提供方
#   dify  = 企业知识库在 Dify（推荐，Spring 只检索）
#   local = Spring AI + PgVector 本地入库
#   none  = 不检索
# ============================================================
CS_AI_KNOWLEDGE_PROVIDER=dify

# ---- Local Chat (llama.cpp OpenAI-compatible) ----
CS_AI_DEFAULT_BASE_URL=http://127.0.0.1:18080/v1
CS_AI_DEFAULT_API_KEY=sk-local
CS_AI_CLASSIFIER_MODEL=local-qwen
CS_AI_ANSWER_STRONG_MODEL=local-qwen
CS_AI_ANSWER_FAST_MODEL=local-qwen

# ---- Local Embedding（仅 knowledge.provider=local 时必需）----
CS_AI_EMBEDDING_BASE_URL=http://127.0.0.1:18081/v1
CS_AI_EMBEDDING_API_KEY=sk-local
CS_AI_EMBEDDING_MODEL=local-bge-m3
CS_AI_EMBEDDING_DIMENSIONS=1024
CS_AI_PGVECTOR_INIT=false

# ============================================================
# 云端可插拔（CS_AI_MODEL_SOURCE=cloud 时启用）
# 本应用 = OpenAI 兼容协议（非 Anthropic / CC Switch 代理）
#   https://dashscope.aliyuncs.com/compatible-mode/v1
# ============================================================
CS_AI_CLOUD_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CS_AI_CLOUD_API_KEY=
CS_AI_CLOUD_CLASSIFIER_MODEL=glm-5.1
CS_AI_CLOUD_ANSWER_STRONG_MODEL=glm-5.1
CS_AI_CLOUD_ANSWER_FAST_MODEL=glm-5.1
CS_AI_CLOUD_EMBEDDING_MODEL=text-embedding-v3
CS_AI_CLOUD_EMBEDDING_DIMENSIONS=1024

# ---- Dify Dataset API（provider=dify）----
# base-url 通常以 /v1 结尾；api-key 为 Dataset API Key
DIFY_BASE_URL=http://127.0.0.1/v1
DIFY_API_KEY=
DIFY_DATASET_ID=
DIFY_TOP_K=5
DIFY_SEARCH_METHOD=hybrid_search

CS_AI_WORKER_ID=1
SERVER_PORT=8081
